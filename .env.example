# LiveKit Cloud project credentials. Keep all three server-side.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match the explicit dispatch name configured by the worker.
LIVEKIT_AGENT_NAME=

# Root URL of api. Internal routes are appended to this URL.
API_URL=http://localhost:4000
VOICE_AGENT_BRIDGE_TOKEN=

# Required server-side credential for transient web searches.
TAVILY_API_KEY=

# Optional bounded web-search configuration.
VOICE_WEB_SEARCH_MAX_RESULTS=5
VOICE_WEB_SEARCH_TIMEOUT_MS=6000

# Optional bounded bridge retry configuration.
VOICE_AGENT_HTTP_TIMEOUT_MS=5000
VOICE_AGENT_HTTP_MAX_ATTEMPTS=4
VOICE_AGENT_HTTP_RETRY_BASE_MS=250

# Optional LiveKit worker logging level. Keep fatal for query privacy: lower
# levels may include raw or malformed tool arguments in LiveKit SDK logs.
# Python maps the compatibility value "fatal" to the "critical" log level.
LOG_LEVEL=fatal
